# FoodFlow Analytics — Environment Variables
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env

# ── PostgreSQL Data Warehouse ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=foodflow_dw
DB_USER=dw_user
DB_PASS=secret

# ── Notes ──────────────────────────────────────────────────────
# DB_PORT  : Host-side port mapped to container port 5432 (see docker-compose.yml)
# DB_USER  : Matches POSTGRES_USER in docker-compose.yml
# DB_PASS  : Matches POSTGRES_PASSWORD in docker-compose.yml
# DB_NAME  : Matches POSTGRES_DB in docker-compose.yml
#
# Inside the Airflow container, the DB_HOST should be "postgres"
# and DB_PORT should be "5432" (container-internal port).
# These are set via AIRFLOW_CONN_FOODFLOW_POSTGRES in docker-compose.yml
# and do NOT need to be changed in this file for local dev.
