# FoodFlow Analytics — Streamlit Secrets Template
# Copy this to .streamlit/secrets.toml (locally) or set them in the 
# Streamlit Cloud dashboard under App Settings -> Secrets.

DB_USER = "dw_user"
DB_PASS = "your_secret_password"
DB_HOST = "your_remote_db_host"
DB_PORT = "5432"
DB_NAME = "foodflow_dw"
